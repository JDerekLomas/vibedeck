#!/bin/bash
# vibedeck launcher: start | stop | status | open | logs
set -uo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PIDFILE="$HOME/.vibedeck/server.pid"
LOG="$HOME/.vibedeck/server.log"
PORT="${VIBEDECK_PORT:-8423}"
mkdir -p "$HOME/.vibedeck"

running() { [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; }

case "${1:-start}" in
  start)
    if running; then echo "vibedeck already running (pid $(cat "$PIDFILE")) — http://127.0.0.1:$PORT"; exit 0; fi
    nohup node "$HERE/src/server.mjs" >> "$LOG" 2>&1 &
    echo $! > "$PIDFILE"
    echo "vibedeck started — http://127.0.0.1:$PORT (log: $LOG)"
    ;;
  stop)
    if running; then kill "$(cat "$PIDFILE")" && rm -f "$PIDFILE" && echo "vibedeck stopped"; else echo "not running"; fi
    ;;
  status)
    if running; then echo "running (pid $(cat "$PIDFILE")) — http://127.0.0.1:$PORT"; else echo "not running"; fi
    ;;
  open)
    running || "$0" start
    open "http://127.0.0.1:$PORT"
    ;;
  logs)
    tail -f "$LOG"
    ;;
  install)
    # launchd-managed: starts at login, restarts if it dies.
    "$0" stop >/dev/null 2>&1
    PLIST="$HOME/Library/LaunchAgents/com.vibedeck.plist"
    NODE="$(command -v node)"
    cat > "$PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.vibedeck</string>
  <key>ProgramArguments</key><array>
    <string>$NODE</string>
    <string>$HERE/src/server.mjs</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>$LOG</string>
  <key>StandardErrorPath</key><string>$LOG</string>
</dict></plist>
EOF
    launchctl unload "$PLIST" 2>/dev/null
    launchctl load "$PLIST"
    echo "vibedeck installed as a login service — http://127.0.0.1:$PORT"
    ;;
  uninstall)
    PLIST="$HOME/Library/LaunchAgents/com.vibedeck.plist"
    launchctl unload "$PLIST" 2>/dev/null; rm -f "$PLIST"
    echo "vibedeck login service removed"
    ;;
  *)
    echo "usage: vibedeck [start|stop|status|open|logs|install|uninstall]"; exit 1
    ;;
esac
